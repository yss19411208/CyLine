# Discord bot token. Never commit the real value.
CYLINE_DISCORD_TOKEN=

# Optional: sync slash commands to one guild for faster development.
CYLINE_DISCORD_GUILD_ID=

# Optional: send a registration notice to this channel from the Discord bot.
CYLINE_DISCORD_NOTIFY_CHANNEL_ID=

# Optional: webhook used by the web API to notify Discord.
CYLINE_DISCORD_WEBHOOK_URL=

# Public GitHub Pages site URL used for the HTML viewer.
CYLINE_PUBLIC_BASE_URL=

# Raw GitHub docs/ URL used for Discord image/data links.
CYLINE_ASSET_BASE_URL=https://raw.githubusercontent.com/yss19411208/CyLine/refs/heads/main/docs/

# Git settings used after saving JSON and images.
CYLINE_AUTO_GIT_COMMIT=true
CYLINE_AUTO_GIT_PUSH=false
CYLINE_GIT_REMOTE=origin
CYLINE_GIT_BRANCH=
CYLINE_GIT_EXECUTABLE=git

# Web API registration.
# If this is blank, the web registration API accepts public submissions.
# Public submissions are convenient but vulnerable to spam.
CYLINE_WEB_API_TOKEN=

# Admin API token. Required for docs/admin.html edits.
CYLINE_ADMIN_TOKEN=
CYLINE_CORS_ALLOWED_ORIGINS=*

# Image upload limit in bytes. Default: 15 MiB.
CYLINE_MAX_SCREENSHOT_BYTES=15728640
